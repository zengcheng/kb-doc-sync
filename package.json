{
  "name": "kb-doc-sync",
  "version": "2.0.0",
  "description": "KB（Confluence）知识库双向同步工具：提取文档为 Markdown / 上传 Markdown 到 KB",
  "main": "cli.js",
  "bin": {
    "kb-doc-sync": "./cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "pull": "node cli.js pull",
    "push": "node cli.js push",
    "test": "node tests/review-fixes.test.js && node tests/cli-base-url.test.js",
    "postinstall": "npx playwright install chromium"
  },
  "keywords": ["confluence", "markdown", "docs", "sync", "upload", "extract"],
  "author": "zengcheng",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "marked": "^15.0.0",
    "playwright": "^1.58.2"
  }
}
